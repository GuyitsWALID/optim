{
  "name": "@optimai/sdk",
  "version": "0.2.0",
  "description": "Optim SDK - Track and optimize AI costs automatically",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GuyitsWALID/optim.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/GuyitsWALID/optim/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/GuyitsWALID/optim/issues"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "keywords": [
    "ai",
    "llm",
    "cost-tracking",
    "openai",
    "optimization"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  }
}
