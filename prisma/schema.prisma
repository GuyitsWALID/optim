// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth Models (Better Auth) ====================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  emailVerified Boolean?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  // Custom fields
  onboardingCompleted Boolean @default(false)
  onboardingData      String?
  organizationId     String?
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@map("user")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  accountId         String
  providerId        String
  accessToken       String?
  refreshToken      String?
  idToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  expiresAt    DateTime
  token        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

// ==================== Core Models ====================

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys         ApiKey[]
  requests        Request[]
  dailySummaries  DailySummary[]
  budgets         Budget[]
  autoOptimize    AutoOptimizeConfig?
  recommendations Recommendation[]
  users           User[]
}

model ApiKey {
  id             String    @id @default(cuid())
  key            String    @unique
  provider       String
  organizationId String
  name           String?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requests     Request[]
}

model Request {
  id             String @id @default(cuid())
  organizationId String
  apiKeyId       String

  model    String
  provider String
  endpoint String?

  promptTokens     Int
  completionTokens Int
  totalTokens      Int

  cost Float

  latency   Int?
  createdAt DateTime @default(now())

  userId  String?
  teamId  String?
  feature String?
  tags    String?

  status       String?
  errorMessage String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKey       ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
}

model DailySummary {
  id             String   @id @default(cuid())
  organizationId String
  date           DateTime @default(now())

  totalRequests    Int
  totalCost        Float
  totalTokens      Int
  promptTokens     Int
  completionTokens Int

  costByProvider String?
  costByModel    String?

  avgLatency Float?
  p95Latency Float?
  p99Latency Float?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
}

model Model {
  id          String  @id @default(cuid())
  name        String  @unique
  provider    String
  displayName String?

  inputPrice  Float
  outputPrice Float

  contextWindow           Int?
  supportsVision          Boolean @default(false)
  supportsFunctionCalling Boolean @default(false)

  capabilityTier String?
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Budget {
  id             String @id @default(cuid())
  organizationId String
  name           String
  amount         Float

  warningAt  Float @default(0.8)
  criticalAt Float @default(0.9)

  currentSpend Float    @default(0)
  periodStart  DateTime
  periodEnd    DateTime

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String
  type           String
  message        String
  metadata       String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model AutoOptimizeConfig {
  id             String @id @default(cuid())
  organizationId String @unique

  isEnabled Boolean @default(false)

  maxSavingsTarget Float  @default(0.3)
  qualityTolerance String @default("moderate")

  excludedEndpoints String?

  alwaysUsePremiumFor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id             String @id @default(cuid())
  organizationId String

  type        String
  priority    String
  title       String
  description String

  estimatedSavings     Float?
  implementationEffort String?

  details String?

  isImplemented Boolean @default(false)
  isDismissed   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CacheEntry {
  id             String @id @default(cuid())
  organizationId String

  cacheKey   String @unique
  promptHash String

  model      String
  response   String
  tokenCount Int

  hitCount  Int      @default(1)
  lastHitAt DateTime @default(now())
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([organizationId, cacheKey])
}
