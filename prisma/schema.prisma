// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth Models (Better Auth) ====================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  emailVerified Boolean?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  // Custom fields
  onboardingCompleted Boolean       @default(false)
  onboardingData      String?
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@map("user")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  type                  String?
  provider              String?
  providerAccountId     String?
  refresh_token         String?   @db.Text
  access_token          String?   @db.Text
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?   @db.Text
  session_state         String?
  accountId             String?
  providerId            String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String?
  userId       String
  expires      DateTime?
  expiresAt    DateTime
  token        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

// ==================== Core Models ====================

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  budgets  Budget[]
  users    User[]
}

model Project {
  id              String    @id @default(cuid())
  name            String
  description     String?
  projectKey      String    @unique // opt_proj_xxxxxxxxxxxx
  providers       String    // JSON array: ["openai", "anthropic"]
  models          String    // JSON array: ["gpt-4o", "claude-sonnet-4-20250514"]
  sdkPlatform     String    // "nodejs" | "python" | "rest"
  organizationId  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastActivityAt  DateTime?

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requests        Request[]
  dailySummaries  DailySummary[]
  autoOptimize    AutoOptimizeConfig?
  recommendations Recommendation[]

  @@index([organizationId])
  @@index([projectKey])
}

model Request {
  id        String @id @default(cuid())
  projectId String

  model    String
  provider String
  endpoint String?

  promptTokens     Int
  completionTokens Int
  totalTokens      Int

  cost Float

  latencyMs     Int?
  isStreaming    Boolean  @default(false)
  originalModel String?  // If auto-optimized, the model originally requested

  createdAt DateTime @default(now())

  userId  String?
  feature String?
  tags    String?

  status       String  @default("success")
  errorType    String?
  statusCode   Int?

  sdkVersion String?
  runtime    String?  // "node" | "python" | "edge" | "rest"

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
}

model DailySummary {
  id        String   @id @default(cuid())
  projectId String
  date      DateTime @default(now())

  totalRequests    Int
  totalCost        Float
  totalTokens      Int
  promptTokens     Int
  completionTokens Int

  costByProvider String?
  costByModel    String?

  avgLatency Float?
  p95Latency Float?
  p99Latency Float?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([projectId])
}

model Model {
  id          String  @id @default(cuid())
  name        String  @unique
  provider    String
  displayName String?

  inputPrice  Float
  outputPrice Float

  contextWindow           Int?
  supportsVision          Boolean @default(false)
  supportsFunctionCalling Boolean @default(false)

  capabilityTier String?
  isActive       Boolean @default(true)

  openRouterId     String?   @unique
  description      String?
  inputModalities  String?
  outputModalities String?
  lastSyncedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Budget {
  id             String @id @default(cuid())
  organizationId String
  name           String
  amount         Float

  warningAt  Float @default(0.8)
  criticalAt Float @default(0.9)

  currentSpend Float    @default(0)
  periodStart  DateTime
  periodEnd    DateTime

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Alert {
  id        String   @id @default(cuid())
  projectId String?
  type      String
  message   String
  metadata  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([projectId])
}

model AutoOptimizeConfig {
  id        String @id @default(cuid())
  projectId String @unique

  isEnabled Boolean @default(false)

  maxSavingsTarget Float  @default(0.3)
  qualityTolerance String @default("moderate") // "strict" | "moderate" | "aggressive"

  excludedEndpoints String?
  routingRules      String? // JSON: model mapping overrides

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id        String @id @default(cuid())
  projectId String

  type        String
  priority    String
  title       String
  description String

  estimatedSavings     Float?
  implementationEffort String?

  details String?

  isImplemented Boolean @default(false)
  isDismissed   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model CacheEntry {
  id             String @id @default(cuid())
  organizationId String

  cacheKey   String @unique
  promptHash String

  model      String
  response   String
  tokenCount Int

  hitCount  Int      @default(1)
  lastHitAt DateTime @default(now())
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([organizationId, cacheKey])
}
